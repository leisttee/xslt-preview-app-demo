{
  "name": "xslt-preview-DEMO",
  "version": "1.0.0",
  "description": "XSLT Preview Tool DEMO",
  "main": "main.js",
  "author": "Teemu Leisto",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "fi.synerall.xslt-preview-demo",
    "productName": "xslt-preview-DEMO",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "demo.js",
      "build/**",
      "assets/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}